# GenLayer ABI Generator - Environment Configuration
# Copy this file to .env and fill in your values

# === Wallet Configuration ===
# Your wallet private key (for deploying/interacting with contracts)
# NEVER commit .env files to git!
PRIVATE_KEY=0x...

# Your wallet address (public)
WALLET_ADDRESS=0x...

# === GenLayer Network ===
# RPC endpoint for the GenLayer testnet
GENLAYER_RPC_URL=https://zksync-os-testnet-genlayer.zksync.dev

# Chain ID for GenLayer testnet
GENLAYER_CHAIN_ID=4221

# === Deployment (optional) ===
# If you have contracts to deploy, set their source paths here
# CONTRACT_SOURCE=./contracts/MyContract.py
# CONTRACT_ADDRESS=0x... (after deployment)
